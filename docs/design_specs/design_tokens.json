    "A2_ANALYZER": { "primary": "#8A2BE2", "aurora_gradient": "linear-gradient(135deg, rgba(138, 43, 226, 0.2), transparent)", "glow_strength": "18px" },
    "A3_CODE_GEN": { "primary": "#00FFC3", "aurora_gradient": "linear-gradient(135deg, rgba(0, 255, 195, 0.2), transparent)", "glow_strength": "12px" },
