      "accent": { "hex": "#FF007A", "name": "Critical Magenta", "rgb": "255, 0, 122" },
      "success": { "hex": "#00FFC3", "name": "Positive Green", "rgb": "0, 255, 195" },
      "warning": { "hex": "#FFD700", "name": "Alert Gold", "rgb": "255, 215, 0" },
      "background_base": { "hex": "#010409", "name": "Deep Midnight", "rgb": "1, 4, 9" },
      "surface_glass": { "hex": "rgba(10, 15, 25, 0.7)", "name": "Obsidian Glass" },
