    "disabled": { "opacity": 0.3, "grayscale": 1, "cursor": "not-allowed" },
    "error_state": { "border": "1px solid #FF007A", "shadow": "critical_error_glow", "shake": "true" }
  },
  "visual_foundation": {
    "colors_palette": {
      "primary": { "hex": "#00F7FF", "name": "Atomic Cyan", "rgb": "0, 247, 255" },
