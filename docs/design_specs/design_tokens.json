    "timings": { "fast": "120ms", "normal": "280ms", "slow": "550ms", "vfx_loop": "12s", "shimmer": "2s" },
    "curves": { "standard": "cubic-bezier(0.25, 0.1, 0.25, 1)", "bounce_out": "cubic-bezier(0.34, 1.56, 0.64, 1)", "entrance": "cubic-bezier(0, 0.55, 0.45, 1)" }
