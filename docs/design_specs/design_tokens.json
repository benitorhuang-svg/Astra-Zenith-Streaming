    "typography_system": {
      "display": { "font": "Outfit", "weight": "900", "letter_spacing": "-1.5px", "transform": "uppercase" },
      "headings": { "font": "Outfit", "weight": "700", "letter_spacing": "0px" },
      "body": { "font": "Outfit", "weight": "400", "line_height": "1.7" },
      "mono": { "font": "JetBrains Mono", "weight": "500", "letter_spacing": "0px" },
      "sizes": {
        "h1": "3.2rem", "h2": "2rem", "h3": "1.3rem",
        "body": "0.95rem", "small": "0.8rem", "tiny": "0.65rem"
