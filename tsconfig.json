{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "dist-server"
  },
  "include": ["src/**/*", "server/**/*"],
  "exclude": ["dist", "node_modules"]
}
