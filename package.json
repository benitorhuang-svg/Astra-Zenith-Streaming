{
  "name": "astra-zenith-streaming-standalone",
  "version": "1.0.0",
  "description": "Standalone Astra Zenith Streaming System (UI + Server)",
  "main": "server/index.ts",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:server\"",
    "dev:ui": "vite",
    "dev:server": "nodemon --delay 2 --watch server --ext ts,js --exec \"tsx server/index.ts\"",
    "dev:browser": "browser-sync start --proxy 'localhost:5180' --files 'src/**/*' 'public/**/*' 'server/**/*' 'index.html' --no-open --reload-delay 800",
    "build:server": "tsc",
    "build": "vite build && npm run build:server",
    "start:prod": "node dist-server/server/index.js",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "setup:specs": "tsx server/scripts/setup_specs.ts",
    "probe": "tsx server/scripts/probe_models.ts"
  },
  "dependencies": {
    "@_davideast/stitch-mcp": "^0.5.2",
    "@agentclientprotocol/sdk": "^0.17.1",
    "@google/genai": "^1.48.0",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/adk-devtools": "^0.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "nodemon": "^3.0.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
